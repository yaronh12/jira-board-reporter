jira:
  base_url: "https://your-org.atlassian.net"

team:
  name: "Your Team Name"
  members:
    - "First Last"

board:
  label: "your-team-label"
  project_keys: []
  jql_filter: ""

slack:
  enabled: true

stale_thresholds:
  epic: 60
  story: 30
  task: 30
  bug: 30
  sub_task: 30
  default: 30

label_sync:
  lookback_days: 7

status_report:
  lookback_days: 7

log_level: "info"
dry_run: false
